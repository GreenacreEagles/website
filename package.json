{
  "name": "greenacre-eagles-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "deploy:worker": "npm run build && wrangler deploy --config dist/server/wrangler.json",
    "serve:dist": "node scripts/serve-dist.mjs",
    "check": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "typecheck": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check",
    "test": "npm run typecheck",
    "test:db": "supabase test db"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.4",
    "@astrojs/sitemap": "^3.5.1",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@tailwindcss/typography": "^0.5.15",
    "astro": "^7.0.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9"
  }
}
