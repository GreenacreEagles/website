---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsCard from "@components/NewsCard.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { newestFirst } from "@lib/content";

const articles = newestFirst(await getCollection("news"));

export const prerender = true;
---

<BaseLayout title="News" description="Latest Greenacre Eagles FC news, announcements, updates, and community stories.">
  <section class="section-pad bg-white">
    <div class="section-shell">
      <SectionHeading eyebrow="Newsroom" title="Latest club news" intro="Updates from match day, registrations, training nights, sponsors, volunteers, and the Eagles community." />
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {articles.map((article) => <NewsCard article={article} />)}
      </div>
    </div>
  </section>
</BaseLayout>

