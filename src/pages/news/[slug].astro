---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import { formatDate } from "@lib/content";

export async function getStaticPaths() {
  const articles = await getCollection("news");
  return articles.map((article) => ({
    params: { slug: article.data.slug ?? article.id },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

export const prerender = true;
---

<BaseLayout title={article.data.title} description={article.data.summary} image={article.data.image}>
  <article class="bg-white">
    <header class="bg-eagles-mist text-eagles-ink">
      <div class="section-shell grid gap-10 py-16 md:py-24 lg:grid-cols-[.9fr_1.1fr] lg:items-end">
        <div>
          <p class="text-sm font-black uppercase text-eagles-green">{article.data.category} / {formatDate(article.data.date)}</p>
          <h1 class="mt-4 font-display text-5xl font-black uppercase leading-none md:text-7xl">{article.data.title}</h1>
          <p class="mt-6 text-xl leading-9 text-eagles-ink/75">{article.data.summary}</p>
        </div>
        <img src={article.data.image ?? "/media/placeholders/matchday-card.svg"} alt="" class="h-96 w-full object-cover shadow-match-card" style="border-radius:8px" />
      </div>
    </header>
    <div class="section-shell max-w-4xl py-14">
      <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:uppercase prose-a:font-bold prose-a:text-eagles-green">
        <Content />
      </div>
      <div class="mt-10 border-t border-eagles-line pt-8">
        <ButtonLink href="/news/" variant="secondary">Back to news</ButtonLink>
      </div>
    </div>
  </article>
</BaseLayout>

