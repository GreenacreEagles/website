---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
---

<BaseLayout title="Login" description="Sign in to the Greenacre Eagles FC portal.">
  <section class="section-pad bg-eagles-mist">
    <div class="section-shell grid gap-10 lg:grid-cols-[.85fr_1.15fr] lg:items-start">
      <div>
        <p class="eyebrow">Club portal</p>
        <h1 class="mt-3 font-display text-5xl font-black uppercase leading-none text-eagles-ink md:text-7xl">Sign in</h1>
        <p class="mt-5 text-lg leading-8 text-eagles-ink/70">
          Access your Greenacre Eagles account for family details, teams, canteen orders, volunteer shifts, events, and club updates.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <ButtonLink href="/portal/" variant="secondary">Open portal</ButtonLink>
          <ButtonLink href="/contact/" variant="ghost">Contact the club</ButtonLink>
        </div>
      </div>

      <div class="surface p-5 md:p-7">
        <div data-auth-config-warning class="hidden border border-eagles-line bg-eagles-mist p-4 text-sm leading-6 text-eagles-ink/75" style="border-radius:8px">
          Portal login is waiting on Supabase environment variables. Add `PUBLIC_SUPABASE_URL` and `PUBLIC_SUPABASE_ANON_KEY` in local, preview, and production environments.
        </div>

        <div class="grid gap-8" data-auth-panel>
          <form class="grid gap-5" data-sign-in-form>
            <div>
              <h2 class="font-display text-3xl font-black uppercase leading-none">Welcome back</h2>
              <p class="mt-3 text-base leading-7 text-eagles-ink/70">Sign in with the email address linked to your club account.</p>
            </div>
            <label>
              <span class="label">Email</span>
              <input class="field" name="email" type="email" autocomplete="email" required />
            </label>
            <label>
              <span class="label">Password</span>
              <input class="field" name="password" type="password" autocomplete="current-password" required />
            </label>
            <button class="focus-ring inline-flex items-center justify-center bg-eagles-green px-5 py-3 text-sm font-black text-white hover:bg-eagles-ink" style="border-radius:8px" type="submit">
              Sign in
            </button>
          </form>

          <form class="grid gap-5 border-t border-eagles-line pt-8" data-sign-up-form>
            <div>
              <h2 class="font-display text-3xl font-black uppercase leading-none">Create an account</h2>
              <p class="mt-3 text-base leading-7 text-eagles-ink/70">
                New accounts start with general access. Club roles are reviewed and assigned by authorised administrators.
              </p>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
              <label>
                <span class="label">Full name</span>
                <input class="field" name="fullName" autocomplete="name" required />
              </label>
              <label>
                <span class="label">Email</span>
                <input class="field" name="email" type="email" autocomplete="email" required />
              </label>
            </div>
            <label>
              <span class="label">Password</span>
              <input class="field" name="password" type="password" autocomplete="new-password" minlength="8" required />
            </label>
            <label class="flex items-start gap-3 text-sm leading-6 text-eagles-ink/70">
              <input class="mt-1" name="terms" type="checkbox" required />
              <span>I agree to the club terms and privacy requirements for using the Greenacre Eagles portal.</span>
            </label>
            <button class="focus-ring inline-flex items-center justify-center border border-eagles-line bg-white px-5 py-3 text-sm font-black text-eagles-ink hover:border-eagles-green hover:bg-eagles-mist" style="border-radius:8px" type="submit">
              Create account
            </button>
          </form>

          <form class="grid gap-4 border-t border-eagles-line pt-8" data-reset-form>
            <div>
              <h2 class="font-display text-2xl font-black uppercase leading-none">Reset password</h2>
              <p class="mt-3 text-sm leading-6 text-eagles-ink/70">We will email you a secure password reset link.</p>
            </div>
            <label>
              <span class="label">Email</span>
              <input class="field" name="email" type="email" autocomplete="email" required />
            </label>
            <button class="focus-ring inline-flex items-center justify-center px-5 py-3 text-sm font-black text-eagles-green hover:text-eagles-ink" type="submit">
              Send reset link
            </button>
          </form>
        </div>

        <p class="mt-5 hidden text-sm font-bold leading-6" data-auth-message></p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { isSupabaseConfigured, supabase } from "@lib/supabaseClient";

  const warning = document.querySelector("[data-auth-config-warning]");
  const panel = document.querySelector("[data-auth-panel]");
  const message = document.querySelector("[data-auth-message]");
  const signInForm = document.querySelector("[data-sign-in-form]");
  const signUpForm = document.querySelector("[data-sign-up-form]");
  const resetForm = document.querySelector("[data-reset-form]");

  const showMessage = (text, isError = false) => {
    if (!message) return;
    message.textContent = text;
    message.classList.remove("hidden", "text-eagles-green", "text-red-700");
    message.classList.add(isError ? "text-red-700" : "text-eagles-green");
  };

  if (!isSupabaseConfigured || !supabase) {
    warning?.classList.remove("hidden");
    panel?.classList.add("hidden");
  }

  signInForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!supabase) return;
    const formData = new FormData(signInForm);
    const { error } = await supabase.auth.signInWithPassword({
      email: String(formData.get("email")),
      password: String(formData.get("password"))
    });
    if (error) {
      showMessage(error.message, true);
      return;
    }
    window.location.href = "/portal/";
  });

  signUpForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!supabase) return;
    const formData = new FormData(signUpForm);
    const { error } = await supabase.auth.signUp({
      email: String(formData.get("email")),
      password: String(formData.get("password")),
      options: {
        emailRedirectTo: `${window.location.origin}/portal/`,
        data: {
          full_name: String(formData.get("fullName"))
        }
      }
    });
    if (error) {
      showMessage(error.message, true);
      return;
    }
    showMessage("Account created. Check your email to verify your address, then return to sign in.");
  });

  resetForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!supabase) return;
    const formData = new FormData(resetForm);
    const { error } = await supabase.auth.resetPasswordForEmail(String(formData.get("email")), {
      redirectTo: `${window.location.origin}/login/`
    });
    showMessage(error ? error.message : "Password reset email sent.", Boolean(error));
  });
</script>
