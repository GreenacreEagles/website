---
import BaseLayout from "@layouts/BaseLayout.astro";
import FormPanel from "@components/FormPanel.astro";
import Icon from "@components/Icon.astro";
import SectionHeading from "@components/SectionHeading.astro";
---

<BaseLayout title="Volunteer" description="Volunteer opportunities at Greenacre Eagles FC for matchdays, canteen, team management, events, and committee support.">
  <section class="section-pad bg-white">
    <div class="section-shell grid gap-10 lg:grid-cols-[.95fr_1.05fr]">
      <div>
        <SectionHeading eyebrow="Volunteer" title="The club runs on people" intro="Parents, supporters, and local helpers make training nights, match days, and club events possible." />
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <article class="surface p-5"><Icon name="users" class="h-8 w-8 text-eagles-green" /><h2 class="mt-4 font-display text-2xl font-black uppercase leading-none">Team managers</h2><p class="mt-3 text-sm leading-6 text-eagles-ink/70">Help squads communicate, organise, and prepare.</p></article>
          <article class="surface p-5"><Icon name="utensils" class="h-8 w-8 text-eagles-green" /><h2 class="mt-4 font-display text-2xl font-black uppercase leading-none">Canteen</h2><p class="mt-3 text-sm leading-6 text-eagles-ink/70">Support matchday fundraising and hospitality.</p></article>
          <article class="surface p-5"><Icon name="shirt" class="h-8 w-8 text-eagles-green" /><h2 class="mt-4 font-display text-2xl font-black uppercase leading-none">Gear</h2><p class="mt-3 text-sm leading-6 text-eagles-ink/70">Assist with kits, equipment, setup, and pack-down.</p></article>
          <article class="surface p-5"><Icon name="heartHandshake" class="h-8 w-8 text-eagles-green" /><h2 class="mt-4 font-display text-2xl font-black uppercase leading-none">Events</h2><p class="mt-3 text-sm leading-6 text-eagles-ink/70">Help with club days, sponsors, fundraisers, and community events.</p></article>
        </div>
      </div>
      <FormPanel title="Volunteer interest" intro="Tell us where you can help and the best way to contact you." intent="Volunteer interest" />
    </div>
  </section>
</BaseLayout>
