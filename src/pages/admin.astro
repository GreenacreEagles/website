---
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import Icon from "@components/Icon.astro";
import SectionHeading from "@components/SectionHeading.astro";
---

<BaseLayout title="Club Office" description="Private content access information for approved Greenacre Eagles FC editors.">
  <section class="section-pad bg-white">
    <div class="section-shell grid gap-10 lg:grid-cols-[.85fr_1.15fr]">
      <SectionHeading eyebrow="Club office" title="Content access for approved club editors" intro="This area is reserved for committee members and approved volunteers who help keep club news, events, sponsors, and team information up to date." />
      <div class="grid gap-5">
        <article class="surface p-6">
          <Icon name="filePen" class="h-8 w-8 text-eagles-green" />
          <h2 class="mt-4 font-display text-3xl font-black uppercase leading-none">Club updates</h2>
          <p class="mt-4 text-base leading-7 text-eagles-ink/70">Approved editors can help keep news, events, team details, sponsors, photos, and homepage announcements current.</p>
        </article>
        <article class="surface p-6">
          <Icon name="shieldCheck" class="h-8 w-8 text-eagles-green" />
          <h2 class="mt-4 font-display text-3xl font-black uppercase leading-none">Editor access</h2>
          <p class="mt-4 text-base leading-7 text-eagles-ink/70">Access is limited to people authorised by the club. Contact the committee if you need to help manage public updates.</p>
        </article>
        <article class="surface p-6">
          <Icon name="gitBranch" class="h-8 w-8 text-eagles-green" />
          <h2 class="mt-4 font-display text-3xl font-black uppercase leading-none">Publishing updates</h2>
          <p class="mt-4 text-base leading-7 text-eagles-ink/70">Public updates are reviewed before they appear online so club information stays clear and accurate.</p>
        </article>
        <div class="flex flex-col gap-3 sm:flex-row">
          <ButtonLink href="/contact/" variant="secondary">Contact the club</ButtonLink>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
