---
import BaseLayout from "@layouts/BaseLayout.astro";

const adminSections = [
  ["Users", "Profiles, families, role requests, and account status."],
  ["Roles", "Scoped assignments, expiry dates, sensitive roles, and audit history."],
  ["Seasons & Teams", "Seasons, competitions, teams, coaches, managers, players, and fixtures."],
  ["Canteen", "Products, stock, orders, vouchers, QR redemption, and canteen shifts."],
  ["Merchandise", "Club gear, variants, stock, orders, refunds, and pickup status."],
  ["Events", "Published events, registrations, attendance, waitlists, and exports."],
  ["Volunteers", "Opportunities, match day shifts, canteen rosters, and participation history."],
  ["Content", "News, announcements, sponsors, documents, policies, and homepage features."],
  ["Coaching", "Training resources, drill library, match reports, and coach documents."],
  ["Reports", "Sales, vouchers, wallets, registrations, volunteers, teams, and audit activity."]
];
---

<BaseLayout title="Admin" description="Greenacre Eagles FC administration portal.">
  <section class="section-pad bg-eagles-mist">
    <div class="section-shell">
      <div class="max-w-3xl">
        <p class="eyebrow">Administration</p>
        <h1 class="mt-3 font-display text-5xl font-black uppercase leading-none text-eagles-ink md:text-7xl">Club operations</h1>
        <p class="mt-5 text-lg leading-8 text-eagles-ink/70">
          Secure tools for authorised Greenacre Eagles staff and committee members to manage the season, teams, canteen, volunteers, content, events, and reporting.
        </p>
      </div>

      <div class="mt-10 surface p-5 md:p-7" data-admin-loading>
        <p class="text-base font-bold text-eagles-ink/70">Checking administrator access...</p>
      </div>

      <div class="mt-10 hidden surface p-5 md:p-7" data-admin-denied>
        <h2 class="font-display text-3xl font-black uppercase leading-none">Access required</h2>
        <p class="mt-3 text-base leading-7 text-eagles-ink/70">
          This area is restricted to approved club administrators and operational staff. Sign in with an authorised account or contact the committee if your access needs review.
        </p>
        <a class="mt-5 inline-flex bg-eagles-green px-5 py-3 text-sm font-black text-white hover:bg-eagles-ink" style="border-radius:8px" href="/login/">Sign in</a>
      </div>

      <div class="mt-10 hidden grid gap-5 md:grid-cols-2 lg:grid-cols-3" data-admin-dashboard>
        {adminSections.map(([title, text]) => (
          <article class="surface p-5">
            <h2 class="font-display text-2xl font-black uppercase leading-none">{title}</h2>
            <p class="mt-3 text-sm leading-6 text-eagles-ink/70">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { isSupabaseConfigured, supabase } from "@lib/supabaseClient";

  const loading = document.querySelector("[data-admin-loading]");
  const denied = document.querySelector("[data-admin-denied]");
  const dashboard = document.querySelector("[data-admin-dashboard]");

  const showDenied = () => {
    loading?.classList.add("hidden");
    dashboard?.classList.add("hidden");
    denied?.classList.remove("hidden");
  };

  if (!isSupabaseConfigured || !supabase) {
    showDenied();
  } else {
    const { data: sessionData } = await supabase.auth.getSession();
    if (!sessionData.session) {
      showDenied();
    } else {
      const checks = await Promise.all([
        supabase.rpc("has_permission", { permission_key: "roles.read" }),
        supabase.rpc("has_permission", { permission_key: "club_structure.manage" }),
        supabase.rpc("has_permission", { permission_key: "content.manage" }),
        supabase.rpc("has_permission", { permission_key: "canteen.orders.manage" })
      ]);
      const allowed = checks.some(({ data }) => data === true);
      loading?.classList.add("hidden");
      if (allowed) {
        denied?.classList.add("hidden");
        dashboard?.classList.remove("hidden");
      } else {
        showDenied();
      }
    }
  }
</script>
