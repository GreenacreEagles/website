---
import EmptyState from "@components/EmptyState.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requirePermission } from "@lib/auth/guards";
import { formatDateTime, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requirePermission(Astro, ["club_structure.manage", "teams.manage", "match_reports.read"]);
if (!session) return Astro.redirect("/login/");

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
const [{ data: fixtures }, { data: training }, { data: reports }, { data: seasons }, { data: teams }, { data: venues }, { data: competitions }] = await Promise.all([
  session.supabase.from("fixtures").select("id,opponent,round,home_away,starts_at,status,teams(name),seasons(name),venues(name)").order("starts_at", { ascending: true }).limit(80),
  session.supabase.from("training_sessions").select("id,starts_at,ends_at,status,teams(name),venues(name)").order("starts_at", { ascending: true }).limit(40),
  session.supabase.from("match_reports").select("id,status,result,final_score_for,final_score_against,teams(name),fixtures(opponent,starts_at),profiles:author_id(full_name,email)").order("created_at", { ascending: false }).limit(40),
  session.supabase.from("seasons").select("id,name").order("starts_on", { ascending: false }),
  session.supabase.from("teams").select("id,name,seasons(name)").order("name"),
  session.supabase.from("venues").select("id,name,suburb").order("name"),
  session.supabase.from("competitions").select("id,name").order("name")
]);
const canWrite = session.permissions.has("*") || session.permissions.has("club_structure.manage") || session.permissions.has("teams.manage");
---

<PortalLayout title="Fixtures and reports" section="Administration" session={session}>
  <div class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <section class="surface p-5 md:p-7">
      <h2 class="font-display text-3xl font-black uppercase leading-none">Fixtures</h2>
      <div class="mt-5 grid gap-3">
        {(fixtures ?? []).length === 0 && <EmptyState title="No fixtures" text="Fixtures will appear here when team draws are entered." />}
        {(fixtures ?? []).map((fixture: any) => (
          <article class="border border-eagles-line bg-white p-4" style="border-radius:8px">
            <p class="font-black">{fixture.teams?.name ?? "Team"} vs {fixture.opponent}</p>
            <p class="text-sm text-eagles-ink/70">{formatDateTime(fixture.starts_at)} - {fixture.venues?.name ?? "venue TBC"}</p>
            <StatusBadge label={statusLabel(fixture.status)} tone={fixture.status === "confirmed" ? "green" : "amber"} />
          </article>
        ))}
      </div>
    </section>
    <aside class="grid gap-5 content-start">
      {success && <p class="border border-eagles-green bg-green-50 p-4 text-sm font-bold text-eagles-green" style="border-radius:8px">{success}</p>}
      {error && <p class="border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-700" style="border-radius:8px">{error}</p>}
      {canWrite && (
        <form class="surface grid gap-4 p-5" method="post" action="/api/admin/create-record/">
          <input type="hidden" name="action" value="fixture" />
          <h2 class="font-display text-2xl font-black uppercase leading-none">Add fixture</h2>
          <label><span class="label">Season</span><select class="field" name="season_id" required><option value="">Select season</option>{(seasons ?? []).map((season) => <option value={season.id}>{season.name}</option>)}</select></label>
          <label><span class="label">Team</span><select class="field" name="team_id" required><option value="">Select team</option>{(teams ?? []).map((team: any) => <option value={team.id}>{team.name} {team.seasons?.name ? `- ${team.seasons.name}` : ""}</option>)}</select></label>
          <label><span class="label">Opponent</span><input class="field" name="opponent" required /></label>
          <div class="grid gap-3 md:grid-cols-2">
            <label><span class="label">Round</span><input class="field" name="round" /></label>
            <label><span class="label">Kick-off</span><input class="field" name="starts_at" type="datetime-local" required /></label>
          </div>
          <label><span class="label">Venue</span><select class="field" name="venue_id"><option value="">Venue TBC</option>{(venues ?? []).map((venue) => <option value={venue.id}>{venue.name}</option>)}</select></label>
          <label><span class="label">Competition</span><select class="field" name="competition_id"><option value="">Not set</option>{(competitions ?? []).map((competition) => <option value={competition.id}>{competition.name}</option>)}</select></label>
          <div class="grid gap-3 md:grid-cols-2">
            <label><span class="label">Home/away</span><select class="field" name="home_away">{["home", "away", "neutral"].map((item) => <option value={item}>{statusLabel(item)}</option>)}</select></label>
            <label><span class="label">Status</span><select class="field" name="status">{["scheduled", "postponed", "cancelled", "completed"].map((item) => <option value={item}>{statusLabel(item)}</option>)}</select></label>
          </div>
          <label><span class="label">Official fixture link</span><input class="field" name="external_url" type="url" /></label>
          <button class="bg-eagles-green px-4 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Add fixture</button>
        </form>
      )}
      {canWrite && (
        <form class="surface grid gap-4 p-5" method="post" action="/api/admin/create-record/">
          <input type="hidden" name="action" value="training" />
          <h2 class="font-display text-2xl font-black uppercase leading-none">Add training</h2>
          <label><span class="label">Team</span><select class="field" name="team_id"><option value="">Whole club</option>{(teams ?? []).map((team: any) => <option value={team.id}>{team.name}</option>)}</select></label>
          <label><span class="label">Venue</span><select class="field" name="venue_id"><option value="">Venue TBC</option>{(venues ?? []).map((venue) => <option value={venue.id}>{venue.name}</option>)}</select></label>
          <div class="grid gap-3 md:grid-cols-2">
            <label><span class="label">Starts</span><input class="field" name="starts_at" type="datetime-local" required /></label>
            <label><span class="label">Ends</span><input class="field" name="ends_at" type="datetime-local" /></label>
          </div>
          <label><span class="label">Notes</span><textarea class="field min-h-24" name="notes"></textarea></label>
          <label><span class="label">Status</span><select class="field" name="status">{["scheduled", "cancelled", "completed"].map((item) => <option value={item}>{statusLabel(item)}</option>)}</select></label>
          <button class="bg-eagles-green px-4 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Add training</button>
        </form>
      )}
      <article class="surface p-5">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Training</h2>
        <div class="mt-4 grid gap-3">
          {(training ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">No training sessions scheduled.</p>}
          {(training ?? []).map((item: any) => <p class="border-t border-eagles-line pt-3 text-sm"><strong>{item.teams?.name ?? "Club"}</strong><br />{formatDateTime(item.starts_at)}</p>)}
        </div>
      </article>
      <article class="surface p-5">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Match reports</h2>
        <div class="mt-4 grid gap-3">
          {(reports ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">No match reports submitted.</p>}
          {(reports ?? []).map((report: any) => <p class="border-t border-eagles-line pt-3 text-sm"><strong>{report.teams?.name ?? "Team"}</strong><br />{statusLabel(report.status)} - {report.result ?? "result TBC"}</p>)}
        </div>
      </article>
    </aside>
  </div>
</PortalLayout>
