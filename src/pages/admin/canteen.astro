---
import EmptyState from "@components/EmptyState.astro";
import AdminDialog from "@components/AdminDialog.astro";
import AdminFeedback from "@components/AdminFeedback.astro";
import AdminPageHeader from "@components/AdminPageHeader.astro";
import FormActions from "@components/FormActions.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requirePermission } from "@lib/auth/guards";
import { formatDateTime, formatMoney, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requirePermission(Astro, ["canteen.manage", "canteen.orders.manage", "canteen.vouchers.manage", "canteen.vouchers.reverse"]);
if (!session) return Astro.redirect("/login/");

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
const [{ data: venues }, { data: groundVenues }, { data: categories }, { data: products }, { data: orders }, { data: vouchers }, { data: redemptions }, { data: profiles }, { data: teams }] = await Promise.all([
  session.supabase.from("canteen_venues").select("id,name,is_active").order("name"),
  session.supabase.from("venues").select("id,name").order("name"),
  session.supabase.from("canteen_categories").select("id,name,is_active").order("display_order"),
  session.supabase.from("canteen_products" as any).select("id,name,price_cents,is_active,is_sold_out,fulfilment_type,stock_quantity,low_stock_threshold,voucher_valid_days,max_quantity_per_order,canteen_categories(name)").order("name").limit(100),
  session.supabase.from("canteen_orders" as any).select("id,order_number,order_status,payment_status,total_cents,created_at,special_instructions,pickup_code,profiles:customer_id(full_name,email),recipient:recipient_id(full_name,email),canteen_venues(name),canteen_order_items(product_name_snapshot,quantity,line_total_cents,fulfilment_type_snapshot,voucher_issuance_id)").order("created_at", { ascending: false }).limit(80),
  session.supabase.from("voucher_issuances").select("id,voucher_type,status,remaining_value_cents,expires_at,profiles:beneficiary_id(full_name,email)").order("created_at", { ascending: false }).limit(80),
  session.supabase.from("voucher_redemptions" as any).select("id,amount_cents,created_at,device_label,status,canteen_venues(name),voucher_issuances(issue_reason,profiles:beneficiary_id(full_name,email)),voucher_reversals(id,reason,created_at)").order("created_at", { ascending: false }).limit(40),
  session.supabase.from("profiles").select("id,full_name,email").order("full_name").limit(200),
  session.supabase.from("teams").select("id,name").order("name")
]);
const canManageCatalog = session.permissions.has("*") || session.permissions.has("canteen.manage");
const canManageVouchers = session.permissions.has("*") || session.permissions.has("canteen.vouchers.manage");
const canReverseVouchers = session.permissions.has("*") || session.permissions.has("canteen.vouchers.reverse");
const canManageOrders = session.permissions.has("*") || session.permissions.has("canteen.orders.manage");
const orderActions: Record<string, { label: string; value: string }[]> = {
  accepted: [
    { label: "Preparing", value: "preparing" },
    { label: "Ready", value: "ready_for_pickup" },
    { label: "Cancel", value: "cancelled" }
  ],
  preparing: [
    { label: "Ready", value: "ready_for_pickup" },
    { label: "Cancel", value: "cancelled" }
  ],
  ready_for_pickup: [{ label: "Collected", value: "collected" }]
};
const productSummaries = (products ?? []).map((product: any) => ({
  ...product,
  stockLabel: product.stock_quantity === null || product.stock_quantity === undefined ? "open stock" : `${product.stock_quantity} left`,
  stockTone:
    product.is_sold_out
      ? "text-red-700"
      : product.stock_quantity !== null && product.stock_quantity !== undefined && product.stock_quantity <= product.low_stock_threshold
        ? "text-amber-700"
        : "text-eagles-ink/70"
}));
---

<PortalLayout title="Canteen operations" section="Administration" session={session}>
  <div class="grid gap-6">
    <AdminFeedback success={success} error={error} />
    <AdminPageHeader title="Canteen operations" intro="Run match day orders, catalogue setup and vouchers with global creation actions separated from live order handling.">
      <Fragment slot="actions">
        {canManageCatalog && (
          <AdminDialog id="add-canteen-venue" title="Add canteen venue" actionLabel="Add venue" size="lg">
            <form class="grid gap-4" method="post" action="/api/admin/create-record/">
              <input type="hidden" name="action" value="canteenVenue" />
              <label><span class="label">Name</span><input class="field" name="name" placeholder="Roberts Park canteen" required /></label>
              <label><span class="label">Ground venue</span><select class="field" name="venue_id"><option value="">Not linked</option>{(groundVenues ?? []).map((venue) => <option value={venue.id}>{venue.name}</option>)}</select></label>
              <label class="inline-flex items-center gap-2 text-sm font-bold"><input type="checkbox" name="is_active" checked /> Active</label>
              <FormActions submitLabel="Add venue" />
            </form>
          </AdminDialog>
        )}
        {canManageCatalog && (
          <AdminDialog id="add-canteen-category" title="Add category" actionLabel="Add category" size="md">
            <form class="grid gap-4" method="post" action="/api/admin/create-record/">
              <input type="hidden" name="action" value="canteenCategory" />
              <label><span class="label">Name</span><input class="field" name="name" placeholder="Hot food" required /></label>
              <label><span class="label">Display order</span><input class="field" name="display_order" type="number" min="0" value="0" /></label>
              <label class="inline-flex items-center gap-2 text-sm font-bold"><input type="checkbox" name="is_active" checked /> Active</label>
              <FormActions submitLabel="Add category" />
            </form>
          </AdminDialog>
        )}
        {canManageCatalog && (
          <AdminDialog id="add-canteen-product" title="Add product" actionLabel="Add product" size="xl">
            <form class="grid gap-4" method="post" action="/api/admin/create-record/">
              <input type="hidden" name="action" value="canteenProduct" />
              <label><span class="label">Category</span><select class="field" name="category_id"><option value="">Uncategorised</option>{(categories ?? []).map((category) => <option value={category.id}>{category.name}</option>)}</select></label>
              <label><span class="label">Name</span><input class="field" name="name" required /></label>
              <label><span class="label">Description</span><textarea class="field min-h-20" name="description"></textarea></label>
              <div class="grid gap-3 md:grid-cols-2">
                <label><span class="label">Price</span><input class="field" name="price" type="number" min="0" step="0.01" required /></label>
                <label><span class="label">Prep minutes</span><input class="field" name="preparation_minutes" type="number" min="0" value="5" /></label>
              </div>
              <div class="grid gap-3 md:grid-cols-2">
                <label><span class="label">Fulfilment</span><select class="field" name="fulfilment_type"><option value="direct_order">Pickup order</option><option value="item_voucher">Wallet voucher</option></select></label>
                <label><span class="label">Max per order</span><input class="field" name="max_quantity_per_order" type="number" min="1" /></label>
              </div>
              <div class="grid gap-3 md:grid-cols-3">
                <label><span class="label">Stock quantity</span><input class="field" name="stock_quantity" type="number" min="0" /></label>
                <label><span class="label">Low stock alert</span><input class="field" name="low_stock_threshold" type="number" min="0" value="5" /></label>
                <label><span class="label">Voucher days</span><input class="field" name="voucher_valid_days" type="number" min="1" value="14" /></label>
              </div>
              <label><span class="label">Dietary tags</span><input class="field" name="dietary_info" placeholder="vegetarian, halal" /></label>
              <label><span class="label">Allergens</span><input class="field" name="allergen_info" placeholder="gluten, dairy" /></label>
              <div class="flex flex-wrap gap-4">
                <label class="inline-flex items-center gap-2 text-sm font-bold"><input type="checkbox" name="is_active" checked /> Active</label>
                <label class="inline-flex items-center gap-2 text-sm font-bold"><input type="checkbox" name="is_sold_out" /> Sold out</label>
              </div>
              <FormActions submitLabel="Add product" />
            </form>
          </AdminDialog>
        )}
        {canManageVouchers && (
          <AdminDialog id="issue-voucher" title="Issue voucher" actionLabel="Issue voucher" size="lg">
            <form class="grid gap-4" method="post" action="/api/admin/create-record/">
              <input type="hidden" name="action" value="voucher" />
              <label><span class="label">Member</span><select class="field" name="beneficiary_id"><option value="">No member selected</option>{(profiles ?? []).map((profile) => <option value={profile.id}>{profile.full_name ?? profile.email}</option>)}</select></label>
              <label><span class="label">Team</span><select class="field" name="team_id"><option value="">No team</option>{(teams ?? []).map((team) => <option value={team.id}>{team.name}</option>)}</select></label>
              <label><span class="label">Venue</span><select class="field" name="venue_id"><option value="">Any canteen</option>{(venues ?? []).map((venue) => <option value={venue.id}>{venue.name}</option>)}</select></label>
              <label><span class="label">Reason</span><input class="field" name="issue_reason" placeholder="Volunteer meal voucher" /></label>
              <div class="grid gap-3 md:grid-cols-2">
                <label><span class="label">Type</span><select class="field" name="voucher_type">{["fixed_amount", "declining_balance", "meal_deal"].map((item) => <option value={item}>{statusLabel(item)}</option>)}</select></label>
                <label><span class="label">Value</span><input class="field" name="value" type="number" min="0" step="0.01" required /></label>
              </div>
              <label><span class="label">Expires</span><input class="field" name="expires_at" type="datetime-local" /></label>
              <FormActions submitLabel="Issue voucher" />
            </form>
          </AdminDialog>
        )}
      </Fragment>
    </AdminPageHeader>
  </div>
  <div class="grid gap-6 xl:grid-cols-[1fr_380px]">
    <section class="surface p-5 md:p-7">
      <h2 class="font-display text-3xl font-black uppercase leading-none">Orders</h2>
      <div class="mt-5 grid gap-3">
        {(orders ?? []).length === 0 && <EmptyState title="No canteen orders" text="Match day canteen orders will appear here once ordering is enabled." />}
        {(orders ?? []).map((order: any) => (
          <article class="border border-eagles-line bg-white p-4" style="border-radius:8px">
            <p class="font-black">Order {order.order_number} - {formatMoney(order.total_cents)}</p>
            <p class="text-sm text-eagles-ink/70">
              {order.profiles?.full_name ?? order.profiles?.email ?? "Customer"}
              {order.recipient?.full_name && order.recipient?.full_name !== order.profiles?.full_name ? ` for ${order.recipient.full_name}` : ""}
              - {formatDateTime(order.created_at)}
            </p>
            {order.pickup_code && <p class="mt-2 inline-flex bg-eagles-mist px-3 py-1 font-mono text-xs font-black text-eagles-ink" style="border-radius:8px">{order.pickup_code}</p>}
            <div class="mt-3 grid gap-2">
              {(order.canteen_order_items ?? []).map((item: any) => (
                <p class="flex justify-between gap-3 border-t border-eagles-line pt-2 text-sm">
                  <span>
                    <strong>{item.quantity}x</strong> {item.product_name_snapshot}
                    <span class="ml-2 text-xs font-bold uppercase text-eagles-ink/50">{statusLabel(item.fulfilment_type_snapshot)}</span>
                    {item.voucher_issuance_id && <span class="ml-2 text-xs font-black text-eagles-green">Voucher issued</span>}
                  </span>
                  <span class="font-bold">{formatMoney(item.line_total_cents)}</span>
                </p>
              ))}
            </div>
            {order.special_instructions && <p class="mt-3 bg-eagles-mist p-3 text-sm font-bold text-eagles-ink" style="border-radius:8px">{order.special_instructions}</p>}
            <div class="mt-2 flex gap-2"><StatusBadge label={statusLabel(order.order_status)} tone="green" /><StatusBadge label={statusLabel(order.payment_status)} tone="ink" /></div>
            {canManageOrders && (
              <div class="mt-4 flex flex-wrap gap-2">
                {["unpaid", "awaiting_payment"].includes(order.payment_status) && (
                  <form method="post" action="/api/admin/canteen-order-status/">
                    <input type="hidden" name="order_id" value={order.id} />
                    <input type="hidden" name="payment_status" value="paid" />
                    <input type="hidden" name="reason" value="Payment received at canteen" />
                    <input type="hidden" name="return_to" value="/admin/canteen/" />
                    <button class="border border-eagles-green px-3 py-2 text-xs font-black text-eagles-green" style="border-radius:8px" type="submit">Mark paid</button>
                  </form>
                )}
                {(orderActions[order.order_status] ?? []).map((action) => (
                  <form method="post" action="/api/admin/canteen-order-status/">
                    <input type="hidden" name="order_id" value={order.id} />
                    <input type="hidden" name="order_status" value={action.value} />
                    <input type="hidden" name="return_to" value="/admin/canteen/" />
                    <button class:list={["px-3 py-2 text-xs font-black", action.value === "cancelled" ? "bg-red-50 text-red-700" : "bg-eagles-green text-white"]} style="border-radius:8px" type="submit">{action.label}</button>
                  </form>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </section>
    <aside class="grid gap-5 content-start">
      <article class="surface p-5"><h2 class="font-display text-2xl font-black uppercase leading-none">Products</h2><div class="mt-4 grid gap-3">{productSummaries.map((product: any) => (
        <p class="border-t border-eagles-line pt-3 text-sm">
          <strong>{product.name}</strong><br />
          {formatMoney(product.price_cents)} - {statusLabel(product.fulfilment_type)} - {product.is_sold_out ? "sold out" : product.is_active ? "available" : "hidden"}<br />
          <span class={product.stockTone}>{product.stockLabel}</span>
          {product.fulfilment_type === "item_voucher" && <span> - valid {product.voucher_valid_days} days</span>}
        </p>
      ))}</div></article>
      <article class="surface p-5"><h2 class="font-display text-2xl font-black uppercase leading-none">Venues</h2><div class="mt-4 grid gap-3">{(venues ?? []).map((venue) => <p class="border-t border-eagles-line pt-3 text-sm"><strong>{venue.name}</strong><br />{venue.is_active ? "active" : "inactive"}</p>)}</div></article>
      <article class="surface p-5"><h2 class="font-display text-2xl font-black uppercase leading-none">Vouchers</h2><div class="mt-4 grid gap-3">{(vouchers ?? []).map((voucher: any) => <p class="border-t border-eagles-line pt-3 text-sm"><strong>{voucher.profiles?.full_name ?? "Member"}</strong><br />{formatMoney(voucher.remaining_value_cents)} - {statusLabel(voucher.status)}</p>)}</div></article>
      <article class="surface p-5">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Voucher claims</h2>
        <div class="mt-4 grid gap-3">
          {(redemptions ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">Voucher claims will appear after canteen staff scan wallet QR codes.</p>}
          {(redemptions ?? []).map((redemption: any) => (
            <div class="border-t border-eagles-line pt-3 text-sm">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="font-black">{formatMoney(redemption.amount_cents)} - {statusLabel(redemption.status)}</p>
                  <p class="text-eagles-ink/70">{redemption.voucher_issuances?.profiles?.full_name ?? redemption.voucher_issuances?.profiles?.email ?? "Member"}</p>
                  <p class="text-eagles-ink/70">{redemption.canteen_venues?.name ?? "Canteen"} - {formatDateTime(redemption.created_at)}</p>
                </div>
                <StatusBadge label={statusLabel(redemption.status)} tone={redemption.status === "reversed" ? "red" : "green"} />
              </div>
              {redemption.voucher_reversals?.[0] && <p class="mt-2 bg-red-50 p-2 text-xs font-bold text-red-700" style="border-radius:8px">Reversed - {redemption.voucher_reversals[0].reason}</p>}
              {canReverseVouchers && redemption.status === "completed" && (
                <form class="mt-3 grid gap-2" method="post" action="/api/admin/reverse-voucher-redemption/">
                  <input type="hidden" name="redemption_id" value={redemption.id} />
                  <input type="hidden" name="return_to" value="/admin/canteen/" />
                  <label><span class="label">Reversal reason</span><input class="field" name="reason" placeholder="Mistaken scan or duplicate claim" required /></label>
                  <button class="bg-red-50 px-3 py-2 text-xs font-black text-red-700" style="border-radius:8px" type="submit">Reverse claim</button>
                </form>
              )}
            </div>
          ))}
        </div>
      </article>
    </aside>
  </div>
</PortalLayout>
