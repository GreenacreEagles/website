---
import EmptyState from "@components/EmptyState.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requirePermission } from "@lib/auth/guards";
import { formatDateTime, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requirePermission(Astro, ["content.manage", "coaching_resources.manage"]);
if (!session) return Astro.redirect("/login/");

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
const canManageContent = session.permissions.has("*") || session.permissions.has("content.manage");
const canManageCoaching = session.permissions.has("*") || session.permissions.has("coaching_resources.manage");

const [{ data: articles }, { data: announcements }, { data: coachingResources }] = await Promise.all([
  session.supabase.from("content_articles").select("id,title,category,workflow_status,publish_at,updated_at,profiles:author_id(full_name,email)").order("updated_at", { ascending: false }).limit(80),
  session.supabase.from("club_announcements").select("id,title,status,priority,starts_at,ends_at,updated_at").order("updated_at", { ascending: false }).limit(80),
  session.supabase.from("coaching_resources").select("id,title,resource_type,status,visibility,duration_minutes,updated_at").order("updated_at", { ascending: false }).limit(80)
]);
---

<PortalLayout title="Content" section="Administration" session={session}>
  <div class="grid gap-6 xl:grid-cols-[1fr_420px]">
    <section class="surface p-5 md:p-7">
      <h2 class="font-display text-3xl font-black uppercase leading-none">Articles</h2>
      <div class="mt-5 grid gap-3">
        {(articles ?? []).length === 0 && <EmptyState title="No articles" text="Club articles, match reports and public updates will appear here once publishing is enabled." />}
        {(articles ?? []).map((article: any) => (
          <article class="border border-eagles-line bg-white p-4" style="border-radius:8px">
            <p class="font-black">{article.title}</p>
            <p class="text-sm text-eagles-ink/70">{article.category ?? "Club news"} - updated {formatDateTime(article.updated_at)}</p>
            <StatusBadge label={statusLabel(article.workflow_status)} tone={article.workflow_status === "published" ? "green" : "amber"} />
          </article>
        ))}
      </div>
    </section>
    <aside class="grid gap-5 content-start">
      {success && <p class="border border-eagles-green bg-green-50 p-4 text-sm font-bold text-eagles-green" style="border-radius:8px">{success}</p>}
      {error && <p class="border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-700" style="border-radius:8px">{error}</p>}
      {canManageContent && <form class="surface grid gap-4 p-5" method="post" action="/api/admin/create-record/">
        <input type="hidden" name="action" value="article" />
        <h2 class="font-display text-2xl font-black uppercase leading-none">Draft article</h2>
        <label><span class="label">Title</span><input class="field" name="title" required /></label>
        <label><span class="label">Slug</span><input class="field" name="slug" placeholder="Auto-generated if empty" /></label>
        <label><span class="label">Summary</span><textarea class="field min-h-20" name="summary"></textarea></label>
        <label><span class="label">Body</span><textarea class="field min-h-36" name="body" required></textarea></label>
        <div class="grid gap-3 md:grid-cols-2">
          <label><span class="label">Category</span><input class="field" name="category" placeholder="Club news" /></label>
          <label><span class="label">Status</span><select class="field" name="workflow_status">{["draft", "in_review", "scheduled", "published", "archived"].map((item) => <option value={item}>{statusLabel(item)}</option>)}</select></label>
        </div>
        <label><span class="label">Publish at</span><input class="field" name="publish_at" type="datetime-local" /></label>
        <label><span class="label">Featured image URL</span><input class="field" name="featured_image_url" type="url" /></label>
        <label><span class="label">Tags</span><input class="field" name="tags" placeholder="juniors, match day" /></label>
        <button class="bg-eagles-green px-4 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Save article</button>
      </form>}
      {canManageCoaching && <form class="surface grid gap-4 p-5" method="post" action="/api/admin/create-record/">
        <input type="hidden" name="action" value="coachingResource" />
        <h2 class="font-display text-2xl font-black uppercase leading-none">Coaching resource</h2>
        <label><span class="label">Title</span><input class="field" name="title" required /></label>
        <label><span class="label">Slug</span><input class="field" name="slug" placeholder="Auto-generated if empty" /></label>
        <div class="grid gap-3 md:grid-cols-2">
          <label><span class="label">Type</span><select class="field" name="resource_type">{["drill", "session_plan", "program", "policy", "video", "document", "external_link"].map((item) => <option value={item}>{statusLabel(item)}</option>)}</select></label>
          <label><span class="label">Visibility</span><select class="field" name="visibility">{["coaches", "team_staff", "admins", "public"].map((item) => <option value={item}>{statusLabel(item)}</option>)}</select></label>
        </div>
        <label><span class="label">Summary</span><textarea class="field min-h-20" name="summary"></textarea></label>
        <label><span class="label">Body</span><textarea class="field min-h-32" name="body" placeholder="Session notes, setup, coaching points or policy detail"></textarea></label>
        <div class="grid gap-3 md:grid-cols-2">
          <label><span class="label">Duration minutes</span><input class="field" name="duration_minutes" type="number" min="0" /></label>
          <label><span class="label">Status</span><select class="field" name="status">{["draft", "published", "archived"].map((item) => <option value={item}>{statusLabel(item)}</option>)}</select></label>
        </div>
        <label><span class="label">External URL</span><input class="field" name="external_url" type="url" placeholder="Video, document or shared drive link" /></label>
        <label><span class="label">Review due</span><input class="field" name="review_due_on" type="date" /></label>
        <label><span class="label">Age groups</span><input class="field" name="age_group_tags" placeholder="U8, U12, Seniors" /></label>
        <label><span class="label">Skill levels</span><input class="field" name="skill_level_tags" placeholder="beginner, intermediate, advanced" /></label>
        <label><span class="label">Equipment</span><input class="field" name="equipment_required" placeholder="cones, bibs, mini goals" /></label>
        <button class="bg-eagles-green px-4 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Save resource</button>
      </form>}
      {canManageContent && <form class="surface grid gap-4 p-5" method="post" action="/api/admin/create-record/">
        <input type="hidden" name="action" value="announcement" />
        <h2 class="font-display text-2xl font-black uppercase leading-none">Add announcement</h2>
        <label><span class="label">Title</span><input class="field" name="title" required /></label>
        <label><span class="label">Message</span><textarea class="field min-h-28" name="message" required></textarea></label>
        <div class="grid gap-3 md:grid-cols-2">
          <label><span class="label">Audience</span><input class="field" name="audience" value="public" /></label>
          <label><span class="label">Priority</span><input class="field" name="priority" type="number" min="0" value="0" /></label>
        </div>
        <div class="grid gap-3 md:grid-cols-2">
          <label><span class="label">Starts</span><input class="field" name="starts_at" type="datetime-local" /></label>
          <label><span class="label">Ends</span><input class="field" name="ends_at" type="datetime-local" /></label>
        </div>
        <label><span class="label">Status</span><select class="field" name="status">{["draft", "published", "archived"].map((item) => <option value={item}>{statusLabel(item)}</option>)}</select></label>
        <button class="bg-eagles-green px-4 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Add announcement</button>
      </form>}
      <article class="surface p-5">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Coaching resources</h2>
        <div class="mt-4 grid gap-3">
          {(coachingResources ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">No coaching resources yet.</p>}
          {(coachingResources ?? []).map((resource: any) => (
            <p class="border-t border-eagles-line pt-3 text-sm">
              <strong>{resource.title}</strong><br />
              {statusLabel(resource.resource_type)} - {statusLabel(resource.visibility)} - {statusLabel(resource.status)}
            </p>
          ))}
        </div>
      </article>
      {canManageContent && <article class="surface p-5">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Announcements</h2>
        <div class="mt-4 grid gap-3">
          {(announcements ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">No announcements yet.</p>}
          {(announcements ?? []).map((notice) => <p class="border-t border-eagles-line pt-3 text-sm"><strong>{notice.title}</strong><br />{statusLabel(notice.status)} - priority {notice.priority}</p>)}
        </div>
      </article>}
    </aside>
  </div>
</PortalLayout>
