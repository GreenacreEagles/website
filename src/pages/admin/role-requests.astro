---
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requirePermission } from "@lib/auth/guards";
import { formatDateTime, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requirePermission(Astro, ["roles.review"]);
if (!session) return Astro.redirect("/login/");

const status = Astro.url.searchParams.get("status") ?? "";
const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
let query = session.supabase
  .from("role_requests")
  .select("id,status,reason,experience,notes,review_note,decision_reason,created_at,submitted_at,reviewed_at,profiles:requester_id(id,full_name,preferred_name,email),roles:requested_role_id(id,name,key),teams(id,name),seasons(id,name)")
  .order("created_at", { ascending: false })
  .limit(100);
if (status) query = query.eq("status", status);
const { data: requests } = await query;
---

<PortalLayout title="Request review" section="Administration" session={session}>
  <section class="surface p-5 md:p-7">
    {success && <p class="mb-5 border border-eagles-green bg-green-50 p-4 text-sm font-bold text-eagles-green" style="border-radius:8px">{success}</p>}
    {error && <p class="mb-5 border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-700" style="border-radius:8px">{error}</p>}
    <form class="flex flex-col gap-3 sm:flex-row sm:items-end" method="get">
      <label><span class="label">Status</span><select class="field" name="status"><option value="">All</option>{["submitted", "under_review", "approved", "rejected", "withdrawn", "cancelled"].map((item) => <option selected={status === item} value={item}>{statusLabel(item)}</option>)}</select></label>
      <button class="bg-eagles-green px-5 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Filter</button>
    </form>

    <div class="mt-6 grid gap-4">
      {(requests ?? []).length === 0 && <p class="text-sm text-eagles-ink/70">No role requests match this view.</p>}
      {(requests ?? []).map((request: any) => (
        <article class="border border-eagles-line bg-white p-4" style="border-radius:8px">
          <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div>
              <h2 class="font-display text-2xl font-black uppercase leading-none">{request.roles?.name}</h2>
              <p class="mt-2 text-sm text-eagles-ink/70">{request.profiles?.preferred_name || request.profiles?.full_name || request.profiles?.email} · {request.teams?.name ?? "Club-wide"} · {request.seasons?.name ?? "Any season"}</p>
              <p class="mt-1 text-xs text-eagles-ink/60">Submitted {formatDateTime(request.submitted_at || request.created_at)}</p>
            </div>
            <StatusBadge label={statusLabel(request.status)} tone={request.status === "approved" ? "green" : request.status === "rejected" ? "red" : "amber"} />
          </div>
          <p class="mt-4 text-sm leading-6 text-eagles-ink/75">{request.reason}</p>
          {["submitted", "under_review"].includes(request.status) && (
            <form class="mt-4 grid gap-3 md:grid-cols-[1fr_160px_160px_160px]" method="post" action="/api/admin/review-role-request/">
              <input type="hidden" name="request_id" value={request.id} />
              <input class="field md:col-span-4" name="review_reason" placeholder="Review note and decision reason" required />
              <input class="field" type="datetime-local" name="starts_at" />
              <input class="field" type="datetime-local" name="ends_at" />
              <button class="bg-eagles-green px-4 py-2 text-sm font-black text-white" style="border-radius:8px" name="decision" value="approved" type="submit">Approve</button>
              <button class="border border-red-200 px-4 py-2 text-sm font-black text-red-700" style="border-radius:8px" name="decision" value="rejected" type="submit">Reject</button>
              <button class="text-left text-sm font-black text-eagles-green" name="decision" value="under_review" type="submit">Mark under review</button>
            </form>
          )}
        </article>
      ))}
    </div>
  </section>
</PortalLayout>
