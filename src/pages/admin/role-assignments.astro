---
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requirePermission } from "@lib/auth/guards";
import { formatDateTime, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requirePermission(Astro, ["roles.read", "roles.assign"]);
if (!session) return Astro.redirect("/login/");

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
const [{ data: assignments }, { data: users }, { data: roles }, { data: teams }, { data: seasons }] = await Promise.all([
  session.supabase.from("user_role_assignments").select("id,status,starts_at,ends_at,reason,profiles:user_id(id,full_name,preferred_name,email),roles(id,name,key),teams(id,name),seasons(id,name)").order("created_at", { ascending: false }).limit(100),
  session.supabase.from("profiles").select("id,full_name,preferred_name,email").order("full_name").limit(200),
  session.supabase.from("role_catalog").select("id,key,name,requires_team_scope,requires_season_scope,requires_super_admin_approval").order("sort_order"),
  session.supabase.from("teams").select("id,name").order("name"),
  session.supabase.from("seasons").select("id,name,status").order("starts_on", { ascending: false })
]);
const canAssign = session.permissions.has("*") || session.permissions.has("roles.assign");
---

<PortalLayout title="Role assignments" section="Administration" session={session}>
  <div class="grid gap-6 xl:grid-cols-[420px_1fr]">
    {canAssign && (
      <form class="surface grid gap-4 p-5 md:p-7" method="post" action="/api/admin/assign-role/">
        <h2 class="font-display text-3xl font-black uppercase leading-none">Assign access</h2>
        {success && <p class="border border-eagles-green bg-green-50 p-4 text-sm font-bold text-eagles-green" style="border-radius:8px">{success}</p>}
        {error && <p class="border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-700" style="border-radius:8px">{error}</p>}
        <label><span class="label">User</span><select class="field" name="user_id" required><option value="">Select user</option>{(users ?? []).map((user) => <option value={user.id}>{user.preferred_name || user.full_name || user.email}</option>)}</select></label>
        <label><span class="label">Role</span><select class="field" name="role_id" required><option value="">Select role</option>{(roles ?? []).map((role: any) => <option value={role.id}>{role.name}</option>)}</select></label>
        <label><span class="label">Team</span><select class="field" name="team_id"><option value="">Club-wide</option>{(teams ?? []).map((team) => <option value={team.id}>{team.name}</option>)}</select></label>
        <label><span class="label">Season</span><select class="field" name="season_id"><option value="">All seasons</option>{(seasons ?? []).map((season) => <option value={season.id}>{season.name}</option>)}</select></label>
        <div class="grid gap-4 md:grid-cols-2">
          <label><span class="label">Starts</span><input class="field" type="datetime-local" name="starts_at" /></label>
          <label><span class="label">Expires</span><input class="field" type="datetime-local" name="ends_at" /></label>
        </div>
        <label><span class="label">Reason</span><textarea class="field min-h-24" name="reason" required></textarea></label>
        <button class="bg-eagles-green px-5 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Confirm assignment</button>
      </form>
    )}

    <section class="surface p-5 md:p-7">
      <h2 class="font-display text-3xl font-black uppercase leading-none">Current and recent assignments</h2>
      <div class="mt-6 grid gap-3">
        {(assignments ?? []).map((assignment: any) => (
          <article class="border border-eagles-line bg-white p-4" style="border-radius:8px">
            <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
              <div>
                <p class="font-black">{assignment.profiles?.preferred_name || assignment.profiles?.full_name || assignment.profiles?.email}</p>
                <p class="text-sm text-eagles-ink/70">{assignment.roles?.name} · {assignment.teams?.name ?? "Club-wide"} · {assignment.seasons?.name ?? "All seasons"}</p>
                <p class="text-xs text-eagles-ink/60">Starts {formatDateTime(assignment.starts_at)} · Expires {formatDateTime(assignment.ends_at)}</p>
              </div>
              <StatusBadge label={statusLabel(assignment.status)} tone={assignment.status === "active" ? "green" : "amber"} />
            </div>
            {canAssign && assignment.status === "active" && (
              <form class="mt-3 grid gap-2 md:grid-cols-[1fr_auto]" method="post" action="/api/admin/revoke-role/">
                <input type="hidden" name="assignment_id" value={assignment.id} />
                <input class="field" name="reason" placeholder="Revocation reason" required />
                <button class="px-4 py-2 text-sm font-black text-red-700" type="submit">Revoke</button>
              </form>
            )}
          </article>
        ))}
      </div>
    </section>
  </div>
</PortalLayout>
