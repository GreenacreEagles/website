---
import PortalLayout from "@layouts/PortalLayout.astro";
import { requireAdmin } from "@lib/auth/guards";

export const prerender = false;

const session = await requireAdmin(Astro);
if (!session) return Astro.redirect("/login/");

const { data: summaryData } = await session.supabase.rpc("admin_dashboard_summary");
const summary = (summaryData ?? {}) as Record<string, number>;
const cards = [
  ["Total profiles", summary.total_profiles ?? 0],
  ["Recent signups", summary.recent_signups ?? 0],
  ["Pending requests", summary.pending_role_requests ?? 0],
  ["Active assignments", summary.active_role_assignments ?? 0],
  ["Expired assignments", summary.expired_assignments ?? 0],
  ["Expiring soon", summary.expiring_soon ?? 0],
  ["Multiple-role users", summary.users_with_multiple_roles ?? 0],
  ["Incomplete profiles", summary.incomplete_profiles ?? 0],
  ["Recent admin actions", summary.recent_admin_actions ?? 0]
];
---

<PortalLayout title="Admin dashboard" section="Administration" session={session}>
  <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
    {cards.map(([label, value]) => (
      <article class="surface p-5">
        <p class="text-sm font-black uppercase tracking-[.14em] text-eagles-green">{label}</p>
        <p class="mt-3 text-5xl font-black text-eagles-ink">{value}</p>
      </article>
    ))}
  </section>
</PortalLayout>
