---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ButtonLink from "@components/ButtonLink.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SponsorStrip from "@components/SponsorStrip.astro";
import { bySortOrder } from "@lib/content";

const sponsors = bySortOrder(await getCollection("sponsors"));

export const prerender = true;
---

<BaseLayout title="Sponsors" description="Greenacre Eagles FC sponsors and local partners supporting community football.">
  <section class="section-pad bg-eagles-mist text-eagles-ink">
    <div class="section-shell grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
      <div>
        <p class="text-sm font-black uppercase text-eagles-green">Sponsors</p>
        <h1 class="mt-4 font-display text-6xl font-black uppercase leading-none md:text-7xl">Back the Eagles</h1>
        <p class="mt-6 max-w-3xl text-xl leading-9 text-eagles-ink/75">A polished sponsor area for local businesses, major partners, community supporters, and in-kind contributors.</p>
      </div>
      <ButtonLink href="/contact/" variant="primary">Become a sponsor</ButtonLink>
    </div>
  </section>
  <section class="section-pad bg-eagles-mist">
    <div class="section-shell">
      <SectionHeading eyebrow="Partners" title="Our club sponsors" intro="Greenacre Eagles is proudly supported by local businesses who help keep football strong in our community." />
      <div class="mt-10">
        <SponsorStrip sponsors={sponsors} />
      </div>
    </div>
  </section>
  <section class="section-pad bg-white">
    <div class="section-shell grid gap-5 md:grid-cols-3">
      <article class="surface p-6"><h2 class="font-display text-3xl font-black uppercase leading-none">Match day support</h2><p class="mt-4 text-base leading-7 text-eagles-ink/70">Sponsors help cover the resources that keep teams prepared and home games running well.</p></article>
      <article class="surface p-6"><h2 class="font-display text-3xl font-black uppercase leading-none">Community</h2><p class="mt-4 text-base leading-7 text-eagles-ink/70">Every partnership supports players, families, volunteers, and junior football in Greenacre.</p></article>
      <article class="surface p-6"><h2 class="font-display text-3xl font-black uppercase leading-none">Partnership</h2><p class="mt-4 text-base leading-7 text-eagles-ink/70">Local businesses are part of the club story, from training nights to presentation day.</p></article>
    </div>
  </section>
</BaseLayout>

