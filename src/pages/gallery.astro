---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { formatDate, newestFirst } from "@lib/content";

const gallery = newestFirst(await getCollection("gallery"));

export const prerender = true;
---

<BaseLayout title="Gallery" description="Greenacre Eagles FC photo and video gallery for matchdays, training, community events, and club life.">
  <section class="section-pad bg-white">
    <div class="section-shell">
      <SectionHeading eyebrow="Gallery" title="Club photos and moments" intro="Scenes from training, match day, presentation nights, and the people who make Greenacre Eagles feel like home." />
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          gallery.map((item) => (
            <article class="surface overflow-hidden">
              <img src={item.data.image} alt="" class="h-64 w-full object-cover" loading="lazy" />
              <div class="p-5">
                <p class="text-sm font-black uppercase text-eagles-green">{item.data.category} / {formatDate(item.data.date)}</p>
                <h2 class="mt-3 font-display text-2xl font-black uppercase leading-none">{item.data.title}</h2>
                <p class="mt-3 text-sm leading-6 text-eagles-ink/70">{item.data.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

