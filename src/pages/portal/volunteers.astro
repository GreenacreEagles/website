---
import EmptyState from "@components/EmptyState.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requireUser } from "@lib/auth/guards";
import { formatDateTime, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requireUser(Astro);
if (!session) return Astro.redirect("/login/");

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
const [{ data: shifts }, { data: assignments }] = await Promise.all([
  session.supabase.from("volunteer_shifts").select("id,starts_at,ends_at,capacity,status,volunteer_opportunities(title,description,opportunity_type),venues(name,suburb),volunteer_assignments(id,status,user_id)").order("starts_at", { ascending: true }).limit(40),
  session.supabase.from("volunteer_assignments").select("id,status,checked_in_at,completed_at,volunteer_shifts(starts_at,volunteer_opportunities(title),venues(name))").eq("user_id", session.user.id).order("created_at", { ascending: false }).limit(20)
]);
---

<PortalLayout title="Volunteers" section="Match day" session={session}>
  <div class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <section class="grid gap-4">
      {success && <p class="border border-eagles-green bg-green-50 p-4 text-sm font-bold text-eagles-green" style="border-radius:8px">{success}</p>}
      {error && <p class="border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-700" style="border-radius:8px">{error}</p>}
      {(shifts ?? []).length === 0 && <EmptyState title="No volunteer shifts open" text="Canteen, setup, pack-down and match day volunteer shifts will appear here when scheduled." />}
      {(shifts ?? []).map((shift: any) => (
        <article class="surface p-5">
          {(() => {
            const myAssignment = shift.volunteer_assignments?.find((assignment: any) => assignment.user_id === session.user.id && assignment.status !== "cancelled");
            return (
              <>
          <p class="eyebrow">{shift.volunteer_opportunities?.opportunity_type ?? "Volunteer shift"}</p>
          <h2 class="mt-2 font-display text-3xl font-black uppercase leading-none text-eagles-ink">{shift.volunteer_opportunities?.title ?? "Club support"}</h2>
          <p class="mt-3 text-sm leading-6 text-eagles-ink/70">{formatDateTime(shift.starts_at)} at {shift.venues?.name ?? "club venue"}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <StatusBadge label={statusLabel(shift.status)} tone={shift.status === "open" ? "green" : "amber"} />
            <StatusBadge label={`${shift.capacity} spots`} tone="ink" />
          </div>
          {!myAssignment && (
            <form class="mt-5" method="post" action="/api/portal/volunteer-shift/">
              <input type="hidden" name="shift_id" value={shift.id} />
              <button class="bg-eagles-green px-4 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Volunteer for this shift</button>
            </form>
          )}
          {myAssignment && (
            <div class="mt-5 flex flex-wrap gap-2">
              <StatusBadge label="You are on this shift" tone="green" />
              {myAssignment.status !== "checked_in" && (
                <form method="post" action="/api/portal/volunteer-assignment/">
                  <input type="hidden" name="assignment_id" value={myAssignment.id} />
                  <input type="hidden" name="status" value="checked_in" />
                  <button class="bg-eagles-green px-4 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Check in</button>
                </form>
              )}
              <form method="post" action="/api/portal/volunteer-assignment/">
                <input type="hidden" name="assignment_id" value={myAssignment.id} />
                <input type="hidden" name="status" value="cancelled" />
                <button class="bg-red-50 px-4 py-3 text-sm font-black text-red-700" style="border-radius:8px" type="submit">Cancel shift</button>
              </form>
            </div>
          )}
              </>
            );
          })()}
        </article>
      ))}
    </section>
    <aside class="surface p-5">
      <h2 class="font-display text-2xl font-black uppercase leading-none">My shifts</h2>
      <div class="mt-4 grid gap-3">
        {(assignments ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">Your volunteer assignments will appear here.</p>}
        {(assignments ?? []).map((assignment: any) => (
          <div class="border-t border-eagles-line pt-3">
            <p class="font-black">{assignment.volunteer_shifts?.volunteer_opportunities?.title ?? "Volunteer shift"}</p>
            <p class="text-sm text-eagles-ink/70">{statusLabel(assignment.status)} - {formatDateTime(assignment.volunteer_shifts?.starts_at)}</p>
            {assignment.status !== "cancelled" && assignment.status !== "completed" && (
              <div class="mt-3 flex flex-wrap gap-2">
                {assignment.status !== "checked_in" && (
                  <form method="post" action="/api/portal/volunteer-assignment/">
                    <input type="hidden" name="assignment_id" value={assignment.id} />
                    <input type="hidden" name="status" value="checked_in" />
                    <button class="text-sm font-black text-eagles-green" type="submit">Check in</button>
                  </form>
                )}
                <form method="post" action="/api/portal/volunteer-assignment/">
                  <input type="hidden" name="assignment_id" value={assignment.id} />
                  <input type="hidden" name="status" value="cancelled" />
                  <button class="text-sm font-black text-red-700" type="submit">Cancel</button>
                </form>
              </div>
            )}
          </div>
        ))}
      </div>
    </aside>
  </div>
</PortalLayout>
