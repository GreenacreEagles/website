---
import EmptyState from "@components/EmptyState.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requireUser } from "@lib/auth/guards";
import { formatDateTime, formatMoney, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requireUser(Astro);
if (!session) return Astro.redirect("/login/");

const [{ data: products }, { data: orders }] = await Promise.all([
  session.supabase.from("merchandise_products").select("id,name,description,category,status,featured,image_url,merchandise_variants(id,size,colour,price_cents,sale_price_cents,stock_quantity,is_active)").eq("status", "active").order("featured", { ascending: false }).limit(60),
  session.supabase.from("merchandise_orders" as any).select("id,order_number,status,total_cents,pickup_or_delivery,created_at,merchandise_order_items(product_name_snapshot,variant_label_snapshot,quantity,line_total_cents)").eq("customer_id", session.user.id).order("created_at", { ascending: false }).limit(20)
]);
const merchOrders = (orders ?? []) as any[];

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
---

<PortalLayout title="Merchandise" section="Club shop" session={session}>
  <div class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <section class="grid gap-4 md:grid-cols-2">
      {success && <p class="border border-eagles-green bg-green-50 p-4 text-sm font-bold text-eagles-green md:col-span-2" style="border-radius:8px">{success}</p>}
      {error && <p class="border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-700 md:col-span-2" style="border-radius:8px">{error}</p>}
      {(products ?? []).length === 0 && <EmptyState title="Club shop coming soon" text="Kit, training gear and supporter items will appear here once merchandise is published." />}
      {(products ?? []).map((product: any) => {
        const variants = (product.merchandise_variants ?? []).filter((variant: any) => variant.is_active && variant.stock_quantity > 0);
        const firstVariant = variants[0] ?? product.merchandise_variants?.[0];
        return (
          <article class="surface overflow-hidden">
            {product.image_url && <img src={product.image_url} alt="" class="h-52 w-full object-cover" loading="lazy" />}
            <div class="p-5">
              <p class="eyebrow">{product.category ?? "Club merchandise"}</p>
              <h2 class="mt-2 font-display text-2xl font-black uppercase leading-none text-eagles-ink">{product.name}</h2>
              <p class="mt-3 text-sm leading-6 text-eagles-ink/70">{product.description ?? "Greenacre Eagles club gear."}</p>
              <p class="mt-4 text-2xl font-black text-eagles-green">{firstVariant ? formatMoney(firstVariant.sale_price_cents ?? firstVariant.price_cents) : "Price TBC"}</p>
              {variants.length > 0 && (
                <form class="mt-5 grid gap-3" method="post" action="/api/portal/merchandise-order/">
                  <label>
                    <span class="label">Option</span>
                    <select class="field" name="variant_id" required>
                      {variants.map((variant: any) => (
                        <option value={variant.id}>
                          {[variant.size, variant.colour].filter(Boolean).join(" / ") || product.name} - {formatMoney(variant.sale_price_cents ?? variant.price_cents)} - {variant.stock_quantity} left
                        </option>
                      ))}
                    </select>
                  </label>
                  <div class="grid gap-3 md:grid-cols-2">
                    <label><span class="label">Qty</span><input class="field" name="quantity" type="number" min="1" max={Math.min(10, firstVariant?.stock_quantity ?? 10)} value="1" /></label>
                    <label><span class="label">Collect</span><select class="field" name="pickup_or_delivery"><option value="pickup">Pickup</option><option value="delivery">Delivery</option></select></label>
                  </div>
                  <label><span class="label">Notes</span><input class="field" name="notes" placeholder="Player name, team, pickup note" /></label>
                  <button class="bg-eagles-green px-4 py-3 text-sm font-black text-white" style="border-radius:8px" type="submit">Place order</button>
                </form>
              )}
              {variants.length === 0 && <p class="mt-4 text-sm font-bold text-eagles-ink/70">Currently out of stock.</p>}
            </div>
          </article>
        );
      })}
    </section>
    <aside class="surface p-5">
      <h2 class="font-display text-2xl font-black uppercase leading-none">My orders</h2>
      <div class="mt-4 grid gap-3">
        {merchOrders.length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">Your merchandise orders will appear here.</p>}
        {merchOrders.map((order) => (
          <div class="border-t border-eagles-line pt-3">
            <p class="font-black">Order {order.order_number}</p>
            <p class="text-sm text-eagles-ink/70">{formatMoney(order.total_cents)} - {formatDateTime(order.created_at)}</p>
            <div class="mt-2 grid gap-1">
              {(order.merchandise_order_items ?? []).map((item: any) => (
                <p class="text-xs font-bold text-eagles-ink/60">
                  {item.quantity}x {item.product_name_snapshot}{item.variant_label_snapshot ? ` - ${item.variant_label_snapshot}` : ""}
                </p>
              ))}
            </div>
            <StatusBadge label={statusLabel(order.status)} tone={order.status === "completed" ? "green" : "amber"} />
          </div>
        ))}
      </div>
    </aside>
  </div>
</PortalLayout>
