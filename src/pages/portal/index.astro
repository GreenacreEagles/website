---
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requireUser } from "@lib/auth/guards";
import { canAccessAdmin, hasAnyPermission } from "@lib/auth/permissions";
import { formatDate, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requireUser(Astro);
if (!session) return Astro.redirect("/login/");

const { data: roleRequests } = await session.supabase
  .from("role_requests")
  .select("id,status,created_at,reason,roles:requested_role_id(name),teams(name),seasons(name)")
  .eq("requester_id", session.user.id)
  .order("created_at", { ascending: false })
  .limit(5);

const { data: announcements } = await session.supabase
  .from("club_announcements")
  .select("title,message,priority,starts_at")
  .eq("status", "published")
  .order("priority", { ascending: false })
  .limit(3);

const isAdmin = canAccessAdmin(session.permissions);
const adminCards = [
  ["Users", "Review profiles and account status.", "/admin/users/", ["users.read"]],
  ["Role requests", "Approve or reject access requests.", "/admin/role-requests/", ["roles.review"]],
  ["Role assignments", "Grant or revoke approved roles.", "/admin/role-assignments/", ["roles.assign"]],
  ["Audit activity", "Review sensitive platform changes.", "/admin/audit/", ["audit.read"]]
].filter((card) => hasAnyPermission(session.permissions, card[3] as string[]));
---

<PortalLayout title="Your club dashboard" section="Member portal" session={session}>
  <div class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <section class="grid gap-5">
      <article class="surface p-5 md:p-7">
        <p class="eyebrow">Welcome</p>
        <h2 class="mt-2 font-display text-3xl font-black uppercase leading-none text-eagles-ink">
          {session.profile.preferred_name || session.profile.full_name || "Greenacre Eagles member"}
        </h2>
        <p class="mt-3 text-base leading-7 text-eagles-ink/70">
          Your portal access is based on approved club roles. Selecting a relationship during signup helps the club understand who you are, but operational access is only granted after review.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a class="inline-flex bg-eagles-green px-4 py-3 text-sm font-black text-white hover:bg-eagles-ink" style="border-radius:8px" href="/portal/account/">Update profile</a>
          <a class="inline-flex border border-eagles-line bg-white px-4 py-3 text-sm font-black text-eagles-ink hover:border-eagles-green" style="border-radius:8px" href="/portal/role-requests/">Request access</a>
        </div>
      </article>

      <div class="grid gap-5 md:grid-cols-2">
        <article class="surface p-5">
          <h2 class="font-display text-2xl font-black uppercase leading-none">Account status</h2>
          <div class="mt-4"><StatusBadge label={statusLabel(session.profile.account_status)} tone="green" /></div>
          <p class="mt-3 text-sm leading-6 text-eagles-ink/70">Created {formatDate(session.profile.created_at)}. Profile {session.profile.onboarding_completed_at ? "is complete" : "still needs a few details"}.</p>
        </article>
        <article class="surface p-5">
          <h2 class="font-display text-2xl font-black uppercase leading-none">Active roles</h2>
          <p class="mt-4 text-4xl font-black text-eagles-green">{session.roleAssignments.length}</p>
          <a class="mt-3 inline-flex text-sm font-black text-eagles-green hover:text-eagles-ink" href="/portal/roles/">View my roles</a>
        </article>
      </div>

      {isAdmin && (
        <section class="grid gap-5 md:grid-cols-2">
          {adminCards.map(([title, text, href]) => (
            <a class="surface block p-5 hover:border-eagles-green" href={href as string}>
              <h2 class="font-display text-2xl font-black uppercase leading-none">{title}</h2>
              <p class="mt-3 text-sm leading-6 text-eagles-ink/70">{text}</p>
            </a>
          ))}
        </section>
      )}
    </section>

    <aside class="grid gap-5 content-start">
      <article class="surface p-5">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Recent requests</h2>
        <div class="mt-4 grid gap-3">
          {(roleRequests ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">No access requests yet.</p>}
          {(roleRequests ?? []).map((request: any) => (
            <div class="border-t border-eagles-line pt-3">
              <p class="font-bold text-eagles-ink">{request.roles?.name ?? "Club role"}</p>
              <p class="text-sm text-eagles-ink/60">{statusLabel(request.status)} · {formatDate(request.created_at)}</p>
            </div>
          ))}
        </div>
      </article>

      <article class="surface p-5">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Club notices</h2>
        <div class="mt-4 grid gap-3">
          {(announcements ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">No current member notices.</p>}
          {(announcements ?? []).map((notice) => (
            <div class="border-t border-eagles-line pt-3">
              <p class="font-bold text-eagles-ink">{notice.title}</p>
              <p class="mt-1 text-sm leading-6 text-eagles-ink/70">{notice.message}</p>
            </div>
          ))}
        </div>
      </article>
    </aside>
  </div>
</PortalLayout>
