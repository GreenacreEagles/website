---
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requireUser } from "@lib/auth/guards";
import { formatDateTime, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requireUser(Astro);
if (!session) return Astro.redirect("/login/");

const { data: assignments } = await session.supabase
  .from("user_role_assignments")
  .select("id,status,starts_at,ends_at,reason,assigned_by,revoked_at,roles(id,key,name,description,is_sensitive),teams(id,name),seasons(id,name)")
  .eq("user_id", session.user.id)
  .order("created_at", { ascending: false });

const now = Date.now();
const assignmentState = (assignment: any) => {
  if (assignment.status === "revoked") return ["Revoked", "red"] as const;
  if (assignment.ends_at && new Date(assignment.ends_at).getTime() <= now) return ["Expired", "amber"] as const;
  if (new Date(assignment.starts_at).getTime() > now) return ["Scheduled", "amber"] as const;
  return [statusLabel(assignment.status), assignment.status === "active" ? "green" : "ink"] as const;
};
---

<PortalLayout title="My roles" section="Access" session={session}>
  <section class="surface p-5 md:p-7">
    <div class="max-w-3xl">
      <h2 class="font-display text-3xl font-black uppercase leading-none">Approved club access</h2>
      <p class="mt-3 text-base leading-7 text-eagles-ink/70">
        These roles come from approved club assignments. They cannot be edited from your account page, and expired or revoked roles do not grant portal permissions.
      </p>
    </div>
    <div class="mt-6 grid gap-4">
      {(assignments ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">No role assignments are linked to your account yet.</p>}
      {(assignments ?? []).map((assignment: any) => {
        const [label, tone] = assignmentState(assignment);
        return (
          <article class="border border-eagles-line bg-white p-4" style="border-radius:8px">
            <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
              <div>
                <h3 class="font-display text-2xl font-black uppercase leading-none">{assignment.roles?.name ?? "Club role"}</h3>
                <p class="mt-2 text-sm leading-6 text-eagles-ink/70">{assignment.roles?.description ?? "Approved Greenacre Eagles access."}</p>
              </div>
              <StatusBadge label={label} tone={tone} />
            </div>
            <dl class="mt-4 grid gap-3 text-sm md:grid-cols-4">
              <div><dt class="font-black">Team</dt><dd>{assignment.teams?.name ?? "Club-wide"}</dd></div>
              <div><dt class="font-black">Season</dt><dd>{assignment.seasons?.name ?? "All seasons"}</dd></div>
              <div><dt class="font-black">Starts</dt><dd>{formatDateTime(assignment.starts_at)}</dd></div>
              <div><dt class="font-black">Expires</dt><dd>{formatDateTime(assignment.ends_at)}</dd></div>
            </dl>
          </article>
        );
      })}
    </div>
  </section>
</PortalLayout>
