---
import EmptyState from "@components/EmptyState.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requireUser } from "@lib/auth/guards";
import { formatDateTime, formatMoney, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requireUser(Astro);
if (!session) return Astro.redirect("/login/");

const [{ data: events }, { data: registrations }] = await Promise.all([
  session.supabase.from("club_events").select("id,title,description,starts_at,ends_at,status,visibility,capacity,price_cents,venues(name,suburb)").order("starts_at", { ascending: true }).limit(40),
  session.supabase.from("event_registrations").select("id,status,created_at,club_events(title,starts_at)").or(`registered_by.eq.${session.user.id},attendee_id.eq.${session.user.id}`).order("created_at", { ascending: false }).limit(20)
]);
---

<PortalLayout title="Events" section="Club life" session={session}>
  <div class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <section class="grid gap-4">
      {(events ?? []).length === 0 && <EmptyState title="No upcoming events" text="Club events, registrations and community nights will appear here when published." />}
      {(events ?? []).map((event: any) => (
        <article class="surface p-5">
          <p class="eyebrow">{formatDateTime(event.starts_at)}</p>
          <h2 class="mt-2 font-display text-3xl font-black uppercase leading-none text-eagles-ink">{event.title}</h2>
          <p class="mt-3 text-sm leading-6 text-eagles-ink/70">{event.description ?? "Event details will be shared by the club."}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <StatusBadge label={statusLabel(event.status)} tone={event.status === "published" ? "green" : "amber"} />
            <StatusBadge label={formatMoney(event.price_cents)} tone="ink" />
            <StatusBadge label={event.venues?.name ?? "Venue TBC"} tone="ink" />
          </div>
        </article>
      ))}
    </section>
    <aside class="surface p-5">
      <h2 class="font-display text-2xl font-black uppercase leading-none">My registrations</h2>
      <div class="mt-4 grid gap-3">
        {(registrations ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">You have no event registrations yet.</p>}
        {(registrations ?? []).map((registration: any) => (
          <div class="border-t border-eagles-line pt-3">
            <p class="font-black">{registration.club_events?.title ?? "Club event"}</p>
            <p class="text-sm text-eagles-ink/70">{statusLabel(registration.status)} - {formatDateTime(registration.club_events?.starts_at)}</p>
          </div>
        ))}
      </div>
    </aside>
  </div>
</PortalLayout>
