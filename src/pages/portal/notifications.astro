---
import EmptyState from "@components/EmptyState.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requireUser } from "@lib/auth/guards";
import { formatDateTime } from "@lib/format";

export const prerender = false;

const session = await requireUser(Astro);
if (!session) return Astro.redirect("/login/");

const { data: notifications } = await session.supabase
  .from("notifications")
  .select("id,title,body,created_at,read_at,related_entity_type")
  .eq("recipient_id", session.user.id)
  .order("created_at", { ascending: false })
  .limit(80);
---

<PortalLayout title="Notifications" section="Member portal" session={session}>
  <section class="grid gap-4">
    {(notifications ?? []).length === 0 && <EmptyState title="No notifications" text="Club notices, role decisions, event reminders and account messages will appear here." />}
    {(notifications ?? []).map((notice) => (
      <article class="surface p-5">
        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="eyebrow">{notice.related_entity_type ?? "Club notice"}</p>
            <h2 class="mt-2 font-display text-2xl font-black uppercase leading-none text-eagles-ink">{notice.title}</h2>
            <p class="mt-3 text-sm leading-6 text-eagles-ink/70">{notice.body}</p>
            <p class="mt-3 text-xs font-bold text-eagles-ink/60">{formatDateTime(notice.created_at)}</p>
          </div>
          <StatusBadge label={notice.read_at ? "Read" : "Unread"} tone={notice.read_at ? "ink" : "green"} />
        </div>
      </article>
    ))}
  </section>
</PortalLayout>
