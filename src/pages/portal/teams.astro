---
import EmptyState from "@components/EmptyState.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import { requireUser } from "@lib/auth/guards";
import { formatDate, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requireUser(Astro);
if (!session) return Astro.redirect("/login/");

const teamIds = session.roleAssignments.map((assignment) => assignment.team?.id).filter(Boolean) as string[];
const canViewClubTeams = session.permissions.has("*") || session.permissions.has("club_structure.manage") || session.permissions.has("teams.manage");

let teams: any[] = [];
if (canViewClubTeams || teamIds.length > 0) {
  let query = session.supabase
    .from("teams")
    .select("id,name,division,colour,status,external_fixture_url,seasons(name,year,status),age_groups(name),competitions(name),venues:training_venue_id(name,suburb)")
    .order("name");
  if (!canViewClubTeams) query = query.in("id", teamIds);
  const { data } = await query;
  teams = data ?? [];
}

const { data: training } = await session.supabase
  .from("training_sessions")
  .select("id,starts_at,ends_at,status,notes,teams(name),venues(name,suburb)")
  .order("starts_at", { ascending: true })
  .limit(12);
---

<PortalLayout title="Teams" section="Football" session={session}>
  <div class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <section class="grid gap-4">
      {teams.length === 0 && (
        <EmptyState title="No teams linked yet" text="Approved team roles and player registrations will appear here once they are connected to your account." href="/portal/role-requests/" action="Request team access" />
      )}
      {teams.map((team) => (
        <article class="surface p-5">
          <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div>
              <p class="eyebrow">{team.seasons?.name ?? "Season"} {team.age_groups?.name ? `- ${team.age_groups.name}` : ""}</p>
              <h2 class="mt-2 font-display text-3xl font-black uppercase leading-none text-eagles-ink">{team.name}</h2>
              <p class="mt-3 text-sm leading-6 text-eagles-ink/70">
                {team.division ?? "Club football"} {team.competitions?.name ? `in ${team.competitions.name}` : ""}
              </p>
            </div>
            <span class="inline-flex bg-eagles-mist px-3 py-2 text-xs font-black uppercase text-eagles-green" style="border-radius:8px">{statusLabel(team.status)}</span>
          </div>
          <dl class="mt-5 grid gap-3 text-sm md:grid-cols-3">
            <div><dt class="font-black">Training venue</dt><dd>{team.venues?.name ?? "To be confirmed"}</dd></div>
            <div><dt class="font-black">Colour</dt><dd>{team.colour ?? "Eagles green"}</dd></div>
            <div><dt class="font-black">Fixtures</dt><dd>{team.external_fixture_url ? <a class="text-eagles-green font-black" href={team.external_fixture_url}>View official draw</a> : "In portal"}</dd></div>
          </dl>
        </article>
      ))}
    </section>

    <aside class="surface p-5">
      <h2 class="font-display text-2xl font-black uppercase leading-none">Training</h2>
      <div class="mt-4 grid gap-3">
        {(training ?? []).length === 0 && <p class="text-sm leading-6 text-eagles-ink/70">Training sessions will appear here once schedules are published.</p>}
        {(training ?? []).map((item: any) => (
          <div class="border-t border-eagles-line pt-3">
            <p class="font-black text-eagles-ink">{item.teams?.name ?? "Club session"}</p>
            <p class="text-sm text-eagles-ink/70">{formatDate(item.starts_at)} at {item.venues?.name ?? "venue TBC"}</p>
          </div>
        ))}
      </div>
    </aside>
  </div>
</PortalLayout>
