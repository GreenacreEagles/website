---
import EmptyState from "@components/EmptyState.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requireUser } from "@lib/auth/guards";
import { formatDate, statusLabel } from "@lib/format";

export const prerender = false;

const session = await requireUser(Astro);
if (!session) return Astro.redirect("/login/");

const [{ data: familyMemberships }, { data: playerRecords }] = await Promise.all([
  session.supabase.from("family_members").select("id,relationship,status,is_primary_guardian,can_manage,can_spend,spending_limit_cents,families(id,name)").eq("user_id", session.user.id),
  session.supabase.from("player_records").select("id,registration_status,photo_consent,code_of_conduct_accepted_at,seasons(name,year)").eq("user_id", session.user.id).order("created_at", { ascending: false })
]);
---

<PortalLayout title="Family and players" section="Members" session={session}>
  <div class="grid gap-6 xl:grid-cols-2">
    <section class="surface p-5 md:p-7">
      <h2 class="font-display text-3xl font-black uppercase leading-none">Family links</h2>
      <div class="mt-5 grid gap-3">
        {(familyMemberships ?? []).length === 0 && <EmptyState title="No family group linked" text="Family groups will show here when guardians, players and spending permissions are connected." />}
        {(familyMemberships ?? []).map((member: any) => (
          <article class="border border-eagles-line bg-white p-4" style="border-radius:8px">
            <p class="font-black text-eagles-ink">{member.families?.name ?? "Family group"}</p>
            <p class="mt-1 text-sm text-eagles-ink/70">{statusLabel(member.relationship)} {member.is_primary_guardian ? "- primary guardian" : ""}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <StatusBadge label={statusLabel(member.status)} tone={member.status === "active" ? "green" : "amber"} />
              {member.can_manage && <StatusBadge label="Can manage" tone="ink" />}
              {member.can_spend && <StatusBadge label="Can spend" tone="green" />}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="surface p-5 md:p-7">
      <h2 class="font-display text-3xl font-black uppercase leading-none">Player records</h2>
      <div class="mt-5 grid gap-3">
        {(playerRecords ?? []).length === 0 && <EmptyState title="No player record yet" text="Player registrations and season records will appear here once connected by the club registrar." />}
        {(playerRecords ?? []).map((record: any) => (
          <article class="border border-eagles-line bg-white p-4" style="border-radius:8px">
            <p class="font-black text-eagles-ink">{record.seasons?.name ?? "Season"} registration</p>
            <p class="mt-1 text-sm text-eagles-ink/70">Code of conduct: {formatDate(record.code_of_conduct_accepted_at)}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <StatusBadge label={statusLabel(record.registration_status)} tone={record.registration_status === "active" ? "green" : "amber"} />
              <StatusBadge label={record.photo_consent ? "Photo consent" : "Photo consent not set"} tone={record.photo_consent ? "green" : "amber"} />
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</PortalLayout>
