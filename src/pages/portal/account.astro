---
import PortalLayout from "@layouts/PortalLayout.astro";
import StatusBadge from "@components/StatusBadge.astro";
import { requireUser } from "@lib/auth/guards";
import { formatDate } from "@lib/format";

export const prerender = false;

const session = await requireUser(Astro);
if (!session) return Astro.redirect("/login/");

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
const profile = session.profile;
---

<PortalLayout title="Profile details" section="My account" session={session}>
  <div class="grid gap-6 xl:grid-cols-[1fr_360px]">
    <form class="surface grid gap-5 p-5 md:p-7" method="post" action="/api/portal/profile">
      {success && <p class="border border-eagles-green bg-green-50 p-4 text-sm font-bold text-eagles-green" style="border-radius:8px">{success}</p>}
      {error && <p class="border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-700" style="border-radius:8px">{error}</p>}
      <div>
        <h2 class="font-display text-3xl font-black uppercase leading-none">Account information</h2>
        <p class="mt-3 text-base leading-7 text-eagles-ink/70">Keep your contact details current so the club can reach you about teams, access, rosters and important updates.</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <label>
          <span class="label">Full name</span>
          <input class="field" name="full_name" autocomplete="name" value={profile.full_name} required />
        </label>
        <label>
          <span class="label">Preferred name</span>
          <input class="field" name="preferred_name" value={profile.preferred_name ?? ""} />
        </label>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <label>
          <span class="label">Mobile</span>
          <input class="field" name="mobile" autocomplete="tel" value={profile.mobile ?? ""} />
        </label>
        <label>
          <span class="label">Relationship to the club</span>
          <select class="field" name="relationship_to_club">
            {["", "Parent or guardian", "Player", "Coach", "Volunteer", "Supporter"].map((option) => (
              <option value={option} selected={(profile.relationship_to_club ?? "") === option}>{option || "Select one"}</option>
            ))}
          </select>
        </label>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <label>
          <span class="label">Emergency contact</span>
          <input class="field" name="emergency_contact_name" value={profile.emergency_contact_name ?? ""} />
        </label>
        <label>
          <span class="label">Emergency phone</span>
          <input class="field" name="emergency_contact_phone" autocomplete="tel" value={profile.emergency_contact_phone ?? ""} />
        </label>
      </div>
      <div class="grid gap-3 text-sm leading-6 text-eagles-ink/70">
        <label class="flex items-center gap-3"><input name="communication_email" type="checkbox" checked={profile.communication_email} /> Email updates</label>
        <label class="flex items-center gap-3"><input name="communication_sms" type="checkbox" checked={profile.communication_sms} /> SMS updates where available</label>
      </div>
      <button class="focus-ring inline-flex items-center justify-center bg-eagles-green px-5 py-3 text-sm font-black text-white hover:bg-eagles-ink" style="border-radius:8px" type="submit">
        Save profile
      </button>
    </form>

    <aside class="grid gap-5 content-start">
      <article class="surface p-5">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Account status</h2>
        <div class="mt-4"><StatusBadge label={profile.account_status} tone="green" /></div>
        <dl class="mt-4 grid gap-3 text-sm">
          <div><dt class="font-black text-eagles-ink">Email</dt><dd class="text-eagles-ink/70">{session.user.email}</dd></div>
          <div><dt class="font-black text-eagles-ink">Created</dt><dd class="text-eagles-ink/70">{formatDate(profile.created_at)}</dd></div>
          <div><dt class="font-black text-eagles-ink">Profile</dt><dd class="text-eagles-ink/70">{profile.onboarding_completed_at ? "Complete" : "Needs details"}</dd></div>
        </dl>
      </article>

      <article class="surface p-5">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Account use</h2>
        <p class="mt-3 text-sm leading-6 text-eagles-ink/70">Use one account for your family, club roles, canteen vouchers, volunteer shifts and team access. Keep your mobile and emergency contact current before match day.</p>
      </article>

      <form class="surface grid gap-4 p-5" method="post" action="/api/portal/password">
        <h2 class="font-display text-2xl font-black uppercase leading-none">Change password</h2>
        <label>
          <span class="label">New password</span>
          <input class="field" name="password" type="password" autocomplete="new-password" minlength="8" required />
        </label>
        <label>
          <span class="label">Confirm password</span>
          <input class="field" name="confirmPassword" type="password" autocomplete="new-password" minlength="8" required />
        </label>
        <button class="text-left text-sm font-black text-eagles-green hover:text-eagles-ink" type="submit">Update password</button>
      </form>
    </aside>
  </div>
</PortalLayout>
