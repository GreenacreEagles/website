---
interface Props {
  id: string;
  title: string;
  actionLabel: string;
  intro?: string;
  size?: "md" | "lg" | "xl";
  tone?: "primary" | "secondary";
}

const { id, title, actionLabel, intro, size = "lg", tone = "primary" } = Astro.props;
const panelSize =
  size === "xl"
    ? "md:max-w-4xl"
    : size === "md"
      ? "md:max-w-xl"
      : "md:max-w-2xl";
const buttonClass =
  tone === "primary"
    ? "bg-eagles-green text-white hover:bg-eagles-ink"
    : "border border-eagles-line bg-white text-eagles-ink hover:border-eagles-green hover:bg-eagles-mist";
---

<button
  class:list={["focus-ring inline-flex min-h-11 items-center justify-center px-4 py-3 text-sm font-black", buttonClass]}
  style="border-radius:8px"
  type="button"
  data-admin-dialog-open={id}
>
  {actionLabel}
</button>

<dialog
  id={id}
  class:list={[
    "admin-dialog m-0 h-dvh max-h-dvh w-screen max-w-none bg-transparent p-0 backdrop:bg-eagles-ink/55 md:m-auto md:h-auto md:w-[calc(100vw-48px)]",
    panelSize
  ]}
  data-admin-dialog
>
  <div class="flex min-h-dvh flex-col bg-white shadow-2xl md:min-h-0 md:max-h-[calc(100vh-48px)]" style="border-radius:12px">
    <header class="flex items-start justify-between gap-4 border-b border-eagles-line p-5">
      <div>
        <h3 class="font-display text-3xl font-black uppercase leading-none text-eagles-ink">{title}</h3>
        {intro && <p class="mt-2 text-sm leading-6 text-eagles-ink/70">{intro}</p>}
      </div>
      <button
        class="focus-ring inline-flex h-10 w-10 shrink-0 items-center justify-center border border-eagles-line text-xl font-black text-eagles-ink hover:border-eagles-green"
        style="border-radius:8px"
        type="button"
        aria-label={`Close ${title}`}
        data-admin-dialog-close
      >
        &times;
      </button>
    </header>
    <div class="overflow-y-auto p-5">
      <slot />
    </div>
  </div>
</dialog>

<script is:inline>
  (() => {
    if (window.__greenacreAdminDialogBound) return;
    window.__greenacreAdminDialogBound = true;
    let lastTrigger = null;

    const firstField = (dialog) =>
      dialog.querySelector("input:not([type='hidden']):not([disabled]), select:not([disabled]), textarea:not([disabled]), button:not([disabled])");

    const isDirty = (dialog) => dialog.querySelector("form[data-admin-dirty='true']");

    const closeDialog = (dialog, force = false) => {
      if (!dialog?.open) return;
      if (!force && isDirty(dialog) && !window.confirm("Close without saving your changes?")) return;
      dialog.close();
      if (lastTrigger instanceof HTMLElement) lastTrigger.focus();
    };

    document.addEventListener("click", (event) => {
      const openButton = event.target.closest("[data-admin-dialog-open]");
      if (openButton) {
        const dialog = document.getElementById(openButton.getAttribute("data-admin-dialog-open"));
        if (dialog?.showModal) {
          lastTrigger = openButton;
          dialog.showModal();
          window.setTimeout(() => firstField(dialog)?.focus(), 50);
        }
      }

      const closeButton = event.target.closest("[data-admin-dialog-close]");
      if (closeButton) closeDialog(closeButton.closest("dialog"));

      if (event.target.matches("dialog[data-admin-dialog]")) closeDialog(event.target);
    });

    document.addEventListener("cancel", (event) => {
      if (!event.target.matches("dialog[data-admin-dialog]")) return;
      if (isDirty(event.target)) {
        event.preventDefault();
        closeDialog(event.target);
      }
    });

    document.addEventListener("input", (event) => {
      const form = event.target.closest("dialog[data-admin-dialog] form");
      if (form) form.dataset.adminDirty = "true";
    });

    document.addEventListener("change", (event) => {
      const form = event.target.closest("dialog[data-admin-dialog] form");
      if (form) form.dataset.adminDirty = "true";
    });

    document.addEventListener("submit", (event) => {
      const form = event.target;
      if (!(form instanceof HTMLFormElement)) return;
      const submitter = event.submitter || form.querySelector("button[type='submit']");
      if (submitter instanceof HTMLButtonElement) {
        submitter.disabled = true;
        submitter.dataset.originalLabel = submitter.textContent || "";
        submitter.textContent = submitter.dataset.loadingLabel || "Saving...";
      }
      form.dataset.adminDirty = "false";
      form.setAttribute("aria-busy", "true");
    });
  })();
</script>
