---
interface Props {
  title: string;
  intro?: string;
}

const { title, intro } = Astro.props;
---

<header class="surface flex flex-col gap-4 p-5 md:flex-row md:items-start md:justify-between md:p-6">
  <div class="max-w-3xl">
    <h2 class="font-display text-3xl font-black uppercase leading-none text-eagles-ink md:text-4xl">{title}</h2>
    {intro && <p class="mt-3 text-sm leading-6 text-eagles-ink/70 md:text-base">{intro}</p>}
  </div>
  <div class="flex flex-wrap gap-2 md:justify-end">
    <slot name="actions" />
  </div>
</header>
