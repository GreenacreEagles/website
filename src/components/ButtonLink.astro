---
import Icon from "@components/Icon.astro";

interface Props {
  href: string;
  variant?: "primary" | "secondary" | "dark" | "light";
  external?: boolean;
}

const { href, variant = "primary", external = false } = Astro.props;

const classes = {
  primary: "bg-eagles-gold text-eagles-ink hover:bg-white",
  secondary: "border border-eagles-green bg-white text-eagles-ink hover:bg-eagles-mist",
  dark: "bg-eagles-ink text-white hover:bg-eagles-green",
  light: "border border-white/20 bg-white/10 text-white hover:bg-white hover:text-eagles-ink"
};
---

<a
  href={href}
  class={`focus-ring inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-black ${classes[variant]}`}
  style="border-radius:8px"
  target={external ? "_blank" : undefined}
  rel={external ? "noreferrer" : undefined}
>
  <slot />
  <Icon name={external ? "arrowUpRight" : "arrowRight"} class="h-4 w-4" />
</a>
