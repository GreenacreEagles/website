---
interface Props {
  label: string;
  value: string | number;
  detail?: string;
}

const { label, value, detail } = Astro.props;
---

<article class="surface p-5">
  <p class="text-xs font-black uppercase tracking-[.14em] text-eagles-green">{label}</p>
  <p class="mt-3 text-4xl font-black text-eagles-ink">{value}</p>
  {detail && <p class="mt-2 text-sm leading-6 text-eagles-ink/60">{detail}</p>}
</article>
