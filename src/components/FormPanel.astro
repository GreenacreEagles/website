---
import { site } from "@data/site";

interface Props {
  title: string;
  intro: string;
  intent?: string;
}

const { title, intro, intent = "Club enquiry" } = Astro.props;
---

<form class="surface grid gap-5 p-5 md:p-7" method="post" action={`mailto:${site.contactEmail}?subject=${encodeURIComponent(intent)}`} enctype="text/plain">
  <div>
    <h2 class="font-display text-3xl font-black uppercase leading-none">{title}</h2>
    <p class="mt-3 text-base leading-7 text-eagles-ink/70">{intro}</p>
  </div>
  <div class="grid gap-4 md:grid-cols-2">
    <label>
      <span class="label">Name</span>
      <input class="field" name="name" autocomplete="name" required />
    </label>
    <label>
      <span class="label">Email</span>
      <input class="field" name="email" type="email" autocomplete="email" required />
    </label>
  </div>
  <label>
    <span class="label">Subject</span>
    <input class="field" name="subject" value={intent} />
  </label>
  <label>
    <span class="label">Message</span>
    <textarea class="field min-h-40" name="message" required></textarea>
  </label>
  <button class="focus-ring inline-flex items-center justify-center bg-eagles-green px-5 py-3 text-sm font-black text-white hover:bg-eagles-ink" style="border-radius:8px" type="submit">
    Send enquiry
  </button>
</form>
